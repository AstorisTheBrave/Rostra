# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
OWNER_IDS=
DEV_GUILD_ID=

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Database (Postgres)
DATABASE_URL=postgresql://user:pass@localhost:5432/rostra?connection_limit=5&pool_timeout=15
# Optional: a direct (non-pooled) connection used only for migrations. Set this when
# DATABASE_URL is a pooled endpoint (e.g. pooled.db.prisma.io, Neon -pooler, pgbouncer),
# otherwise `prisma migrate deploy` fails with P1002 (advisory lock). Leave unset when
# DATABASE_URL is already a direct connection (Docker compose, a plain Postgres).
DIRECT_URL=

# Cache / queues (optional - in-memory fallback if unset)
REDIS_URL=

# Web (health + webhooks)
PORT=3000
HOST=0.0.0.0

# Sharding (native by default; set hybrid for clustering, see docs/infrastructure/hybrid-sharding.mdx)
TOTAL_SHARDS=
SHARDING_MODE=native
# Hybrid clustering only: shards per cluster process (requires REDIS_URL)
SHARDS_PER_CLUSTER=

# AI (neutral names - provider is an implementation detail)
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Translation drafts tooling (dev only; npm run i18n:draft)
TRANSLATE_API_KEY=
TRANSLATE_BASE_URL=
TRANSLATE_MODEL=

# Music (Lavalink - JSON array of nodes with failover)
LAVALINK_NODES=[]
LAVALINK_RECONNECT_TRIES=5
LAVALINK_RESUME=true
LAVALINK_REST_TIMEOUT=10000

# top.gg (optional)
TOPGG_TOKEN=
TOPGG_WEBHOOK_AUTH=
TOPGG_BOT_ID=

# Twitch app credentials (optional; needed only for Twitch live feeds)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
