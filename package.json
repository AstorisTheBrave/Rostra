{
	"name": "rostra",
	"version": "0.1.2",
	"description": "All-in-one Discord bot",
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "tsx watch src/cluster.ts",
		"build": "prisma generate && tsc --noEmit",
		"start": "tsx src/cluster.ts",
		"start:panel": "node panel-start.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "node --import tsx --test \"src/**/*.test.ts\"",
		"test:env": "node --import tsx --env-file=.env --test \"src/**/*.test.ts\"",
		"deploy:commands": "node --import tsx --env-file-if-exists=.env src/scripts/deploy-commands.ts",
		"lavalink:check": "node --import tsx --env-file-if-exists=.env src/scripts/lavalink-check.ts",
		"emojis:generate": "node --import tsx src/scripts/generate-emojis.ts",
		"emojis:upload": "node --import tsx --env-file-if-exists=.env src/scripts/upload-emojis.ts",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate deploy",
		"i18n:bundle": "node --import tsx src/scripts/i18n-bundle.ts",
		"i18n:coverage": "node --import tsx --env-file-if-exists=.env src/scripts/i18n-coverage.ts",
		"i18n:push": "node --import tsx --env-file-if-exists=.env src/scripts/i18n-push.ts",
		"i18n:validate": "node --import tsx --env-file-if-exists=.env src/scripts/i18n-validate.ts",
		"i18n:draft": "node --import tsx --env-file-if-exists=.env src/scripts/i18n-draft.ts"
	},
	"dependencies": {
		"@fastify/rate-limit": "^11.0.0",
		"@keyv/redis": "^5.1.6",
		"@napi-rs/canvas": "^1.0.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@top-gg/sdk": "^3.1.6",
		"bad-words": "^4.0.0",
		"bullmq": "^5.79.1",
		"discord-hybrid-sharding": "^3.0.1",
		"discord.js": "^14.16.3",
		"fastify": "^5.1.0",
		"intl-messageformat": "^11.2.8",
		"ioredis": "^5.4.1",
		"keyv": "^5.2.1",
		"lavalink-client": "^2.10.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.0.0",
		"tsx": "^4.19.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@resvg/resvg-js": "^2.6.2",
		"@types/node": "^26.0.0",
		"dotenv": "^17.2.3",
		"lucide-static": "^1.21.0",
		"prisma": "^7.8.0",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"undici": "^6.26.0",
		"@hono/node-server": "^1.19.13",
		"esbuild": "^0.28.1"
	}
}
