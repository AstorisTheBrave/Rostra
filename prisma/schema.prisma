generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Guild {
  id        String   @id
  prefix    String?
  locale    String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  modules   GuildModuleConfig[]
  members   GuildMember[]
}

model GuildModuleConfig {
  id       String  @id @default(cuid())
  guildId  String
  module   String
  enabled  Boolean @default(true)
  settings Json    @default("{}")
  guild    Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, module])
  @@index([guildId])
}

model User {
  id        String        @id
  createdAt DateTime      @default(now())
  members   GuildMember[]
  votes     UserVote[]
}

model GuildMember {
  id      String @id @default(cuid())
  guildId String
  userId  String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
}

model Blacklist {
  id        String   @id @default(cuid())
  targetId  String   @unique
  scope     String // "user" | "guild"
  reason    String?
  createdAt DateTime @default(now())
}

model UserVote {
  id        String   @id @default(cuid())
  userId    String
  votedAt   DateTime @default(now())
  isWeekend Boolean  @default(false)
  source    String   @default("topgg")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OwnerAudit {
  id        String   @id @default(cuid())
  ownerId   String
  action    String
  detail    Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([ownerId])
}

// ── Moderation ──────────────────────────────────────────────────────────────

/// A single moderation action. Warnings (type="warn") and notes (type="note")
/// share this table with infractions (ban/kick/timeout/untimeout/unban).
model ModerationCase {
  id          String   @id @default(cuid())
  guildId     String
  caseNumber  Int
  type        String // ban | kick | timeout | untimeout | unban | warn | note
  targetId    String
  moderatorId String
  reason      String?
  durationMs  Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([guildId, caseNumber])
  @@index([guildId, targetId])
  @@index([guildId, type])
}

/// Per-guild monotonically increasing case counter.
model GuildCaseCounter {
  guildId String @id
  count   Int    @default(0)
}

// ── Security / Antinuke ──────────────────────────────────────────────────────

/// Per-guild antinuke configuration. Absent row = antinuke not set up (disabled).
model AntinukeConfig {
  guildId         String   @id
  enabled         Boolean  @default(false)
  punishment      String   @default("ban") // ban | kick | strip
  logChannelId    String?
  notifyOwner     Boolean  @default(true)
  antiBan         Boolean  @default(true)
  antiKick        Boolean  @default(true)
  antiBotAdd      Boolean  @default(true)
  antiChannel     Boolean  @default(true)
  antiRole        Boolean  @default(true)
  antiWebhook     Boolean  @default(true)
  antiGuildUpdate Boolean  @default(true)
  extraOwners     String[] @default([])
  whitelist       String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Automod ──────────────────────────────────────────────────────────────────

/// Per-guild auto-moderation configuration.
model AutomodConfig {
  guildId         String   @id
  enabled         Boolean  @default(false)
  logChannelId    String?
  antiInvite      Boolean  @default(false)
  antiLink        Boolean  @default(false)
  antiSpam        Boolean  @default(false)
  antiMassMention Boolean  @default(false)
  antiProfanity   Boolean  @default(false)
  antiCaps        Boolean  @default(false)
  action          String   @default("delete") // delete | warn | timeout
  timeoutMs       Int      @default(300000)
  spamCount       Int      @default(5)
  spamWindowMs    Int      @default(5000)
  mentionLimit    Int      @default(5)
  capsPercent     Int      @default(70)
  capsMinLength   Int      @default(10)
  exemptRoles     String[] @default([])
  exemptChannels  String[] @default([])
  customWords     String[] @default([])
  allowedLinks    String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Logging ──────────────────────────────────────────────────────────────────

/// Per-guild audit logging configuration.
model LoggingConfig {
  guildId         String   @id
  logChannelId    String?
  messageDelete   Boolean  @default(true)
  messageEdit     Boolean  @default(true)
  memberJoin      Boolean  @default(true)
  memberLeave     Boolean  @default(true)
  memberBan       Boolean  @default(true)
  memberUnban     Boolean  @default(true)
  roleChanges     Boolean  @default(true)
  channelChanges  Boolean  @default(true)
  ignoredChannels String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Welcome / Autorole ───────────────────────────────────────────────────────

/// Per-guild welcome, goodbye, and auto-role configuration.
model WelcomeConfig {
  guildId          String   @id
  welcomeEnabled   Boolean  @default(false)
  welcomeChannelId String?
  welcomeMessage   String   @default("Welcome {user} to **{server}**! You're member #{membercount}.")
  goodbyeEnabled   Boolean  @default(false)
  goodbyeChannelId String?
  goodbyeMessage   String   @default("**{username}** has left the server.")
  dmEnabled        Boolean  @default(false)
  dmMessage        String   @default("Welcome to {server}! We're glad to have you.")
  autoroleIds      String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Tickets ──────────────────────────────────────────────────────────────────

/// Per-guild ticket system configuration.
model TicketConfig {
  guildId        String   @id
  enabled        Boolean  @default(false)
  categoryId     String?
  logChannelId   String?
  supportRoleIds String[] @default([])
  panelTitle     String   @default("Need help?")
  panelMessage   String   @default("Click the button below to open a ticket.")
  openMessage    String   @default("Thanks for opening a ticket. Support will be with you shortly.")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// An open or closed support ticket.
model Ticket {
  id        String   @id @default(cuid())
  guildId   String
  channelId String   @unique
  userId    String
  number    Int
  claimedBy String?
  open      Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([guildId, number])
  @@index([guildId, userId])
}

/// Per-guild ticket number counter.
model GuildTicketCounter {
  guildId String @id
  count   Int    @default(0)
}

// ── Economy ──────────────────────────────────────────────────────────────────

/// A member's per-guild economy account.
model EconomyUser {
  guildId   String
  userId    String
  wallet    Int       @default(0)
  bank      Int       @default(0)
  streak    Int       @default(0)
  lastDaily DateTime?
  lastWork  DateTime?
  lastCrime DateTime?
  lastRob   DateTime?
  updatedAt DateTime  @updatedAt

  @@id([guildId, userId])
  @@index([guildId])
}

// ── Leveling ─────────────────────────────────────────────────────────────────

model LevelConfig {
  guildId           String   @id
  enabled           Boolean  @default(false)
  announceChannelId String?
  xpMin             Int      @default(10)
  xpMax             Int      @default(20)
  cooldownMs        Int      @default(60000)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LevelUser {
  guildId   String
  userId    String
  xp        Int      @default(0)
  level     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([guildId, userId])
  @@index([guildId])
}

model LevelReward {
  guildId String
  level   Int
  roleId  String

  @@id([guildId, level])
  @@index([guildId])
}

// ── Giveaways ────────────────────────────────────────────────────────────────

model Giveaway {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  messageId String?
  prize     String
  winners   Int      @default(1)
  hostId    String
  endsAt    DateTime
  ended     Boolean  @default(false)
  entries   String[] @default([])
  createdAt DateTime @default(now())

  @@index([guildId, ended])
  @@index([ended])
}

// ── Join to Create (temp voice) ──────────────────────────────────────────────

model JoinToCreateConfig {
  guildId      String   @id
  hubChannelId String?
  categoryId   String?
  nameTemplate String   @default("{user}'s channel")
  userLimit    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model J2CChannel {
  channelId String   @id
  guildId   String
  ownerId   String
  createdAt DateTime @default(now())

  @@index([guildId])
}

// ── Reaction Roles (button self-roles) ───────────────────────────────────────

model ReactionRolePanel {
  id        String   @id @default(cuid())
  guildId   String
  channelId String?
  messageId String?
  title     String
  mode      String   @default("multiple") // multiple | single
  roles     Json     @default("[]") // [{ roleId, label, emoji? }]
  createdAt DateTime @default(now())

  @@index([guildId])
}

// ── Birthdays ────────────────────────────────────────────────────────────────

model BirthdayConfig {
  guildId   String   @id
  channelId String?
  roleId    String?
  message   String   @default("🎂 Happy birthday {user}!")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Birthday {
  guildId String
  userId  String
  day     Int
  month   Int
  year    Int?

  @@id([guildId, userId])
  @@index([month, day])
}

// ── Extras (afk / autoresponder) ─────────────────────────────────────────────

model AfkStatus {
  guildId String
  userId  String
  reason  String
  since   DateTime @default(now())

  @@id([guildId, userId])
}

model AutoResponder {
  id       String @id @default(cuid())
  guildId  String
  trigger  String
  response String

  @@unique([guildId, trigger])
  @@index([guildId])
}

// ── Reputation ───────────────────────────────────────────────────────────────

model RepUser {
  guildId   String
  userId    String
  points    Int       @default(0) // reputation received
  lastGiven DateTime? // when this user last gave rep (24h cooldown)

  @@id([guildId, userId])
  @@index([guildId])
}

// ── Sticky messages ──────────────────────────────────────────────────────────

model StickyMessage {
  channelId     String  @id
  guildId       String
  content       String
  lastMessageId String? // id of the most recent repost, deleted before the next

  @@index([guildId])
}

// ── Highlights ───────────────────────────────────────────────────────────────

model Highlight {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  word      String // stored lowercased
  createdAt DateTime @default(now())

  @@unique([guildId, userId, word])
  @@index([guildId])
}

// ── Trivia ───────────────────────────────────────────────────────────────────

model TriviaScore {
  guildId   String
  userId    String
  correct   Int      @default(0)
  total     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([guildId, userId])
  @@index([guildId])
}

// ── Tags (custom text snippets) ──────────────────────────────────────────────

model Tag {
  guildId   String
  name      String
  content   String
  createdBy String
  uses      Int      @default(0)
  createdAt DateTime @default(now())

  @@id([guildId, name])
  @@index([guildId])
}

// ── Vanity status roles ──────────────────────────────────────────────────────

model VanityRoleConfig {
  guildId String  @id
  enabled Boolean @default(false)
  keyword String?
  roleId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Feedback ─────────────────────────────────────────────────────────────────

model FeedbackConfig {
  guildId   String  @id
  channelId String?
  anonymous Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Reminders ────────────────────────────────────────────────────────────────

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  guildId   String
  channelId String
  message   String
  dueAt     DateTime
  createdAt DateTime @default(now())

  @@index([guildId])
  @@index([userId])
}

// ── User profiles (image cards) ──────────────────────────────────────────────

model Profile {
  userId     String   @id
  bio        String?
  background String?
  accent     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Global bot state (singletons: command-registration hash, etc.) ───────────

model BotState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Centralized per-guild config (the "tenant") ──────────────────────────────
// One cached row per guild for cross-cutting settings the setup wizard writes
// and multiple features resolve from cache (no raw lookups on hot paths).

model GuildTenant {
  guildId          String   @id
  locale           String   @default("en")
  logChannelId     String?
  modLogChannelId  String?
  welcomeChannelId String?
  muteRoleId       String?
  // Feature enable flags, e.g. { "automod": true, "logging": true }.
  features         Json     @default("{}")
  // Free-form per-guild settings stashed by the wizard/features.
  settings         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Verification gate ────────────────────────────────────────────────────────

model VerificationConfig {
  guildId   String   @id
  roleId    String?
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Notification feeds (YouTube / Twitch) ────────────────────────────────────

model FeedSubscription {
  id         String   @id @default(cuid())
  guildId    String
  channelId  String
  type       String // "youtube" | "twitch"
  sourceId   String // YouTube channel id (UC...) or Twitch login
  sourceName String?
  lastItemId String? // last video id / last live stream id seen
  mention    String? // role id, "everyone", or null
  createdAt  DateTime @default(now())

  @@unique([guildId, type, sourceId])
  @@index([guildId])
}

// ── Starboard ────────────────────────────────────────────────────────────────

model StarboardConfig {
  guildId         String   @id
  channelId       String?
  threshold       Int      @default(3)
  emoji           String   @default("⭐")
  selfStar        Boolean  @default(false)
  ignoreBots      Boolean  @default(true)
  syncDeletes     Boolean  @default(true)
  ignoredChannels String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StarboardEntry {
  id                 String   @id @default(cuid())
  guildId            String
  channelId          String
  messageId          String   @unique
  starboardMessageId String?
  authorId           String
  stars              Int      @default(0)
  createdAt          DateTime @default(now())

  @@index([guildId])
  @@index([guildId, authorId])
}

// ── Durable scheduler ────────────────────────────────────────────────────────
// One row per future action (reminder, giveaway end, tempban/mute/role lift,
// ticket auto-close, ...). Survives restart/crash; re-armed per shard on boot.

model ScheduledTask {
  id        String   @id @default(cuid())
  type      String
  runAt     DateTime
  guildId   String?
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([runAt])
  @@index([guildId])
}
