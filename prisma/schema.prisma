generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guild {
  id        String   @id
  prefix    String?
  locale    String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  modules   GuildModuleConfig[]
  members   GuildMember[]
}

model GuildModuleConfig {
  id       String  @id @default(cuid())
  guildId  String
  module   String
  enabled  Boolean @default(true)
  settings Json    @default("{}")
  guild    Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, module])
  @@index([guildId])
}

model User {
  id        String        @id
  createdAt DateTime      @default(now())
  members   GuildMember[]
  votes     UserVote[]
}

model GuildMember {
  id      String @id @default(cuid())
  guildId String
  userId  String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
}

model Blacklist {
  id        String   @id @default(cuid())
  targetId  String   @unique
  scope     String // "user" | "guild"
  reason    String?
  createdAt DateTime @default(now())
}

model UserVote {
  id        String   @id @default(cuid())
  userId    String
  votedAt   DateTime @default(now())
  isWeekend Boolean  @default(false)
  source    String   @default("topgg")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OwnerAudit {
  id        String   @id @default(cuid())
  ownerId   String
  action    String
  detail    Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([ownerId])
}

// ── Moderation ──────────────────────────────────────────────────────────────

/// A single moderation action. Warnings (type="warn") and notes (type="note")
/// share this table with infractions (ban/kick/timeout/untimeout/unban).
model ModerationCase {
  id          String   @id @default(cuid())
  guildId     String
  caseNumber  Int
  type        String // ban | kick | timeout | untimeout | unban | warn | note
  targetId    String
  moderatorId String
  reason      String?
  durationMs  Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([guildId, caseNumber])
  @@index([guildId, targetId])
  @@index([guildId, type])
}

/// Per-guild monotonically increasing case counter.
model GuildCaseCounter {
  guildId String @id
  count   Int    @default(0)
}

// ── Security / Antinuke ──────────────────────────────────────────────────────

/// Per-guild antinuke configuration. Absent row = antinuke not set up (disabled).
model AntinukeConfig {
  guildId         String   @id
  enabled         Boolean  @default(false)
  punishment      String   @default("ban") // ban | kick | strip
  logChannelId    String?
  notifyOwner     Boolean  @default(true)
  antiBan         Boolean  @default(true)
  antiKick        Boolean  @default(true)
  antiBotAdd      Boolean  @default(true)
  antiChannel     Boolean  @default(true)
  antiRole        Boolean  @default(true)
  antiWebhook     Boolean  @default(true)
  antiGuildUpdate Boolean  @default(true)
  extraOwners     String[] @default([])
  whitelist       String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Automod ──────────────────────────────────────────────────────────────────

/// Per-guild auto-moderation configuration.
model AutomodConfig {
  guildId         String   @id
  enabled         Boolean  @default(false)
  logChannelId    String?
  antiInvite      Boolean  @default(false)
  antiLink        Boolean  @default(false)
  antiSpam        Boolean  @default(false)
  antiMassMention Boolean  @default(false)
  antiProfanity   Boolean  @default(false)
  antiCaps        Boolean  @default(false)
  action          String   @default("delete") // delete | warn | timeout
  timeoutMs       Int      @default(300000)
  spamCount       Int      @default(5)
  spamWindowMs    Int      @default(5000)
  mentionLimit    Int      @default(5)
  capsPercent     Int      @default(70)
  capsMinLength   Int      @default(10)
  exemptRoles     String[] @default([])
  exemptChannels  String[] @default([])
  customWords     String[] @default([])
  allowedLinks    String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Logging ──────────────────────────────────────────────────────────────────

/// Per-guild audit logging configuration.
model LoggingConfig {
  guildId         String   @id
  logChannelId    String?
  messageDelete   Boolean  @default(true)
  messageEdit     Boolean  @default(true)
  memberJoin      Boolean  @default(true)
  memberLeave     Boolean  @default(true)
  memberBan       Boolean  @default(true)
  memberUnban     Boolean  @default(true)
  roleChanges     Boolean  @default(true)
  channelChanges  Boolean  @default(true)
  ignoredChannels String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Welcome / Autorole ───────────────────────────────────────────────────────

/// Per-guild welcome, goodbye, and auto-role configuration.
model WelcomeConfig {
  guildId          String   @id
  welcomeEnabled   Boolean  @default(false)
  welcomeChannelId String?
  welcomeMessage   String   @default("Welcome {user} to **{server}**! You're member #{membercount}.")
  goodbyeEnabled   Boolean  @default(false)
  goodbyeChannelId String?
  goodbyeMessage   String   @default("**{username}** has left the server.")
  dmEnabled        Boolean  @default(false)
  dmMessage        String   @default("Welcome to {server}! We're glad to have you.")
  autoroleIds      String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Tickets ──────────────────────────────────────────────────────────────────

/// Per-guild ticket system configuration.
model TicketConfig {
  guildId        String   @id
  enabled        Boolean  @default(false)
  categoryId     String?
  logChannelId   String?
  supportRoleIds String[] @default([])
  panelTitle     String   @default("Need help?")
  panelMessage   String   @default("Click the button below to open a ticket.")
  openMessage    String   @default("Thanks for opening a ticket. Support will be with you shortly.")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// An open or closed support ticket.
model Ticket {
  id        String   @id @default(cuid())
  guildId   String
  channelId String   @unique
  userId    String
  number    Int
  claimedBy String?
  open      Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([guildId, number])
  @@index([guildId, userId])
}

/// Per-guild ticket number counter.
model GuildTicketCounter {
  guildId String @id
  count   Int    @default(0)
}

// ── Economy ──────────────────────────────────────────────────────────────────

/// A member's per-guild economy account.
model EconomyUser {
  guildId   String
  userId    String
  wallet    Int       @default(0)
  bank      Int       @default(0)
  streak    Int       @default(0)
  lastDaily DateTime?
  lastWork  DateTime?
  lastCrime DateTime?
  lastRob   DateTime?
  updatedAt DateTime  @updatedAt

  @@id([guildId, userId])
  @@index([guildId])
}

// ── Leveling ─────────────────────────────────────────────────────────────────

model LevelConfig {
  guildId           String   @id
  enabled           Boolean  @default(false)
  announceChannelId String?
  xpMin             Int      @default(10)
  xpMax             Int      @default(20)
  cooldownMs        Int      @default(60000)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LevelUser {
  guildId   String
  userId    String
  xp        Int      @default(0)
  level     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([guildId, userId])
  @@index([guildId])
}

model LevelReward {
  guildId String
  level   Int
  roleId  String

  @@id([guildId, level])
  @@index([guildId])
}

// ── Giveaways ────────────────────────────────────────────────────────────────

model Giveaway {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  messageId String?
  prize     String
  winners   Int      @default(1)
  hostId    String
  endsAt    DateTime
  ended     Boolean  @default(false)
  entries   String[] @default([])
  createdAt DateTime @default(now())

  @@index([guildId])
  @@index([ended])
}

// ── Join to Create (temp voice) ──────────────────────────────────────────────

model JoinToCreateConfig {
  guildId      String   @id
  hubChannelId String?
  categoryId   String?
  nameTemplate String   @default("{user}'s channel")
  userLimit    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model J2CChannel {
  channelId String   @id
  guildId   String
  ownerId   String
  createdAt DateTime @default(now())

  @@index([guildId])
}

// ── Reaction Roles (button self-roles) ───────────────────────────────────────

model ReactionRolePanel {
  id        String   @id @default(cuid())
  guildId   String
  channelId String?
  messageId String?
  title     String
  mode      String   @default("multiple") // multiple | single
  roles     Json     @default("[]") // [{ roleId, label, emoji? }]
  createdAt DateTime @default(now())

  @@index([guildId])
}

// ── Birthdays ────────────────────────────────────────────────────────────────

model BirthdayConfig {
  guildId   String   @id
  channelId String?
  roleId    String?
  message   String   @default("🎂 Happy birthday {user}!")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Birthday {
  guildId String
  userId  String
  day     Int
  month   Int
  year    Int?

  @@id([guildId, userId])
  @@index([month, day])
}
